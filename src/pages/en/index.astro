---
// EN Home page
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ServiceCard from '../../components/ServiceCard.astro';

const en = await import('../../i18n/en.json');
const t = en.default;

const trustItems = [
  { value: '27', label: t.trust.years },
  { value: '800', label: t.trust.companies },
  { value: '45', label: t.trust.guarantees + ' (M €)' },
];

const services = [
  { icon: 'guarantee', ...t.services.service1 },
  { icon: 'compass', ...t.services.service2 },
  { icon: 'briefcase', ...t.services.service3 },
];

const partners = [
  { name: 'Finpromoter', logo: 'images/partners/finpromoter.png', href: 'https://www.finpromoter.it/' },
  { name: 'Fondo di Garanzia', logo: 'images/partners/fondo-garanzia.png', href: 'https://www.fondidigaranzia.it/' },
  { name: 'Ascom', logo: 'images/partners/ascom.png', href: 'https://www.ascom-tdg.it/' },
  { name: 'BCP', logo: 'images/partners/bcp.jpg', href: 'https://www.bcp.it/' },
  { name: 'BPER', logo: 'images/partners/bper.png', href: 'https://www.bper.it/' },
  { name: 'MCC', logo: 'images/partners/mcc.jpg', href: 'https://www.fdg.mcc.it/' },
];
---

<BaseLayout
  title="Home"
  description={t.site.description}
  lang="en"
  currentPath="/en"
>
  <Hero
    title={t.hero.title}
    subtitle={t.hero.subtitle}
    cta1={t.hero.cta1}
    cta1Href="/en/services"
    cta2={t.hero.cta2}
    cta2Href="/en/contact"
  />

  <TrustBar items={trustItems} lang="en" />

  <!-- Services -->
  <section class="section">
    <div class="container-custom">
      <h2 class="section-title">{t.services.title}</h2>
      <p class="section-subtitle">{t.services.subtitle}</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mt-12">
        {services.map((service, i) => (
          <ServiceCard
            icon={service.icon}
            title={service.title}
            description={service.desc}
            index={i}
          />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={import.meta.env.BASE_URL + 'en/services/'} class="btn btn-outline">{t.cta.servizi}</a>
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="section bg-bg-alt">
    <div class="container-custom">
      <h2 class="section-title">{t.partners.title}</h2>
      <p class="section-subtitle">{t.partners.subtitle}</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6 md:gap-8 mt-12 items-center">
        {partners.map(partner => (
          <a
            href={partner.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center p-4 bg-white rounded-xl border border-border-light hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 group"
            aria-label={partner.name}
          >
            <img
              src={import.meta.env.BASE_URL + partner.logo}
              alt={partner.name}
              class="max-h-12 w-auto grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
              width="120"
              height="48"
              loading="lazy"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section">
    <div class="container-custom">
      <div class="bg-primary rounded-2xl px-8 py-12 md:px-16 md:py-16 text-center text-white">
        <h2 class="text-white mb-4">Become a member of Impresa Confidi</h2>
        <p class="text-white/80 max-w-xl mx-auto mb-8 text-lg">
          Join the hundreds of businesses that have chosen to grow with us. Discover the benefits of membership.
        </p>
        <a href={import.meta.env.BASE_URL + 'en/contact/'} class="btn bg-white text-primary hover:bg-gray-100 inline-flex">Contact us now</a>
      </div>
    </div>
  </section>
</BaseLayout>
