---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const en = await import('../../i18n/en.json');
const t = en.default;
---

<BaseLayout
  title="Contact"
  description="Contact Impresa Confidi SCpA: phone, email, certified email and office in Torre del Greco (NA), Italy."
  lang="en"
  currentPath="/en/contact"
>
  <PageHeader title={t.contact.title} subtitle={t.contact.subtitle} />

  <section class="section">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-primary mb-8">Our details</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary-light text-primary flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h3 class="font-semibold mb-1">Registered Office</h3>
                <p class="text-text-light">{t.contact.address}</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary-light text-primary flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
              </div>
              <div>
                <h3 class="font-semibold mb-1">Email</h3>
                <a href="mailto:impresaconfidi@gmail.com" class="text-primary hover:text-primary-dark transition-colors">impresaconfidi@gmail.com</a>
                <p class="text-text-light text-sm mt-1">Certified Email: impresaconfidi@pec.it</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-primary-light text-primary flex items-center justify-center flex-shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold mb-1">Phone</h3>
                <a href="tel:+390813580367" class="text-primary hover:text-primary-dark transition-colors">{t.contact.phone}</a>
              </div>
            </div>
          </div>

          <div class="mt-10 p-10 bg-bg-alt rounded-xl border border-border-light text-center">
            <svg class="w-16 h-16 mx-auto text-text-light mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <p class="text-text-light text-sm">Via Cappuccini 64<br/>80059 Torre del Greco (NA)<br/>Italy</p>
          </div>
        </div>

        <div class="card self-start lg:sticky lg:top-24">
          <h2 class="text-primary mb-2">Write to us</h2>
          <p class="text-text-light text-sm mb-6">Fill in the form and we will get back to you as soon as possible.</p>

          <form action="https://formspree.io/f/impresaconfidi@gmail.com" method="POST" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-text mb-1.5">{t.contact.form.name}</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-border bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-text mb-1.5">{t.contact.form.email}</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-border bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-text mb-1.5">{t.contact.form.message}</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-border bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-text resize-none"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full">{t.contact.form.send}</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
