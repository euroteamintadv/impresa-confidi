---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const partners = [
  { name: 'Finpromoter', logo: 'images/partners/finpromoter.png', href: 'https://www.finpromoter.it/', category: 'Finance' },
  { name: 'Fondo di Garanzia', logo: 'images/partners/fondo-garanzia.png', href: 'https://www.fondidigaranzia.it/', category: 'Institutions' },
  { name: 'Ascom', logo: 'images/partners/ascom.png', href: 'https://www.ascom-tdg.it/', category: 'Associations' },
  { name: 'BCP', logo: 'images/partners/bcp.jpg', href: 'https://www.bcp.it/', category: 'Banks' },
  { name: 'BPER', logo: 'images/partners/bper.png', href: 'https://www.bper.it/', category: 'Banks' },
  { name: 'MCC', logo: 'images/partners/mcc.jpg', href: 'https://www.fdg.mcc.it/', category: 'Institutions' },
];
---

<BaseLayout
  title="Partners"
  description="Partners and affiliates of Impresa Confidi: banks, institutions and associations collaborating with our confidi."
  lang="en"
  currentPath="/en/partners"
>
  <PageHeader title="Partners & Affiliates" subtitle="A trusted network for businesses" />

  <section class="section">
    <div class="container-custom">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {partners.map(partner => (
          <a
            href={partner.href}
            target="_blank"
            rel="noopener noreferrer"
            class="card group flex flex-col items-center text-center py-10"
          >
            <img
              src={import.meta.env.BASE_URL + partner.logo}
              alt={partner.name}
              class="h-24 w-auto mb-6 grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-300"
              width="160"
              height="64"
              loading="lazy"
            />
            <h3 class="text-lg mb-1 group-hover:text-primary transition-colors">{partner.name}</h3>
            <span class="text-xs text-text-light bg-bg-alt px-3 py-1 rounded-full">{partner.category}</span>
          </a>
        ))}
      </div>

      <div class="mt-16 text-center max-w-lg mx-auto">
        <div class="card">
          <h3 class="mb-3">Want to become a partner?</h3>
          <p class="text-text-light text-sm mb-4">
            Are you a bank or an entity interested in collaborating with Impresa Confidi? Contact us to explore new opportunities.
          </p>
          <a href={import.meta.env.BASE_URL + 'en/contact/'} class="btn btn-primary text-sm px-5 py-2">Contact us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
