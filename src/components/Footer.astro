---
interface Link {
  label: string;
  href: string;
}

interface Props {
  currentPath: string;
  navItems: Link[];
  footer: {
    chiSiamo: string;
    desc: string;
    contatti: string;
    linkUtili: string;
    copyright: string;
    piva: string;
    pec: string;
  };
  contact: {
    address: string;
    phone: string;
  };
  nav: {
    privacy: string;
    cookie: string;
  };
}

const { currentPath, navItems, footer, contact, nav } = Astro.props;

const policyLinks = [
  { label: nav.privacy, href: currentPath.startsWith('/en') ? '/en/privacy' : '/privacy' },
  { label: nav.cookie, href: currentPath.startsWith('/en') ? '/en/cookie' : '/cookie' },
];
---

<footer class="bg-bg-alt border-t border-border-light" role="contentinfo">
  <div class="container-custom py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo.svg" alt="Impresa Confidi" class="h-8 w-auto" width="32" height="32" />
          <span class="font-serif font-bold text-lg text-text">Impresa Confidi</span>
        </div>
        <p class="text-text-light text-sm leading-relaxed">{footer.desc}</p>
        <p class="text-text-light text-xs mt-3">{footer.piva}</p>
      </div>

      <div>
        <h4 class="font-serif font-semibold text-text text-base mb-4">{footer.linkUtili}</h4>
        <ul class="space-y-2">
          {navItems.map(link => <li><a href={link.href} class="text-text-light hover:text-primary transition-colors text-sm">{link.label}</a></li>)}
        </ul>
      </div>

      <div>
        <h4 class="font-serif font-semibold text-text text-base mb-4">{footer.contatti}</h4>
        <div class="space-y-3 text-sm text-text-light">
          <p class="flex items-start gap-2">
            <span class="text-primary font-bold mr-1">&bull;</span>
            {contact.address}
          </p>
          <p>
            <a href="mailto:impresaconfidi@gmail.com" class="hover:text-primary transition-colors">
              impresaconfidi@gmail.com
            </a>
          </p>
          <p class="text-xs">{footer.pec}</p>
          <p>
            <a href="tel:+390813580367" class="hover:text-primary transition-colors">
              {contact.phone}
            </a>
          </p>
        </div>
      </div>
    </div>

    <div class="border-t border-border-light mt-10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        {policyLinks.map(link => <a href={link.href} class="text-text-light hover:text-primary transition-colors text-xs">{link.label}</a>)}
      </div>
      <p class="text-text-light text-xs">
        &copy; {new Date().getFullYear()} Impresa Confidi SCpA &mdash; {footer.copyright}
      </p>
    </div>
  </div>
</footer>
