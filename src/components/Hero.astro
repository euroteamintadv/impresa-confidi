---
interface Props {
  title: string;
  subtitle: string;
  cta1: string;
  cta1Href: string;
  cta2: string;
  cta2Href: string;
}

const { title, subtitle, cta1, cta1Href, cta2, cta2Href } = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-dark via-primary to-[#1a5fb4]">
  <!-- Geometric pattern overlay -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5"/>
        </pattern>
        <pattern id="dots" width="120" height="120" patternUnits="userSpaceOnUse">
          <circle cx="60" cy="60" r="1.5" fill="white"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"/>
      <rect width="100%" height="100%" fill="url(#dots)"/>
    </svg>
  </div>

  <!-- Decorative circles echoing the logo -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] border border-white/10 rounded-full -translate-y-1/2 translate-x-1/4" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] border border-white/10 rounded-full translate-y-1/3 -translate-x-1/4" aria-hidden="true"></div>
  <div class="absolute top-1/2 right-1/4 w-[200px] h-[200px] border border-white/5 rounded-full" aria-hidden="true"></div>

  <div class="container-custom relative py-20 md:py-28 lg:py-36">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Logo + Text -->
      <div class="text-center lg:text-left order-2 lg:order-1">
        <h1 class="text-white mb-6 animate-fade-in-up leading-tight">
          {title}
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-xl mb-10 leading-relaxed animate-fade-in-up" style="animation-delay: 0.1s">
          {subtitle}
        </p>
        <div class="flex flex-col sm:flex-row items-center lg:items-start gap-4 animate-fade-in-up" style="animation-delay: 0.2s">
          <a href={import.meta.env.BASE_URL + cta1Href.slice(1)} class="btn bg-white text-primary hover:bg-gray-100 shadow-lg hover:shadow-xl">
            {cta1}
          </a>
          <a href={import.meta.env.BASE_URL + cta2Href.slice(1)} class="btn border-2 border-white/30 text-white hover:bg-white/10">
            {cta2}
          </a>
        </div>
      </div>

      <!-- Right: Logo -->
      <div class="flex justify-center lg:justify-end order-1 lg:order-2 animate-fade-in-up">
        <div class="relative">
          <div class="absolute inset-0 bg-white/25 rounded-full blur-2xl" aria-hidden="true"></div>
          <img
            src={import.meta.env.BASE_URL + 'images/logo.svg'}
            alt="Impresa Confidi"
            class="relative w-48 h-48 md:w-64 md:h-64 lg:w-80 lg:h-80 drop-shadow-2xl"
            width="274"
            height="291"
          />
        </div>
      </div>
    </div>
  </div>
</section>
