---
// Hero section component
interface Props {
  title: string;
  subtitle: string;
  cta1: string;
  cta1Href: string;
  cta2: string;
  cta2Href: string;
}

const { title, subtitle, cta1, cta1Href, cta2, cta2Href } = Astro.props;
---

<section class="relative overflow-hidden bg-bg">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-primary translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-accent -translate-x-1/3 translate-y-1/3"></div>
  </div>

  <div class="container-custom relative py-20 md:py-32 lg:py-40">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Logo mark above title -->
      <div class="mb-8 animate-fade-in-up">
        <img src={import.meta.env.BASE_URL + 'images/logo.svg'} alt="" class="h-16 md:h-20 mx-auto" width="80" height="80" aria-hidden="true" />
      </div>

      <h1 class="mb-6 animate-fade-in-up" style="animation-delay: 0.1s">
        {title}
      </h1>

      <p class="text-lg md:text-xl text-text-light max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in-up" style="animation-delay: 0.2s">
        {subtitle}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.3s">
        <a href={import.meta.env.BASE_URL + cta1Href.slice(1)} class="btn btn-primary">{cta1}</a>
        <a href={import.meta.env.BASE_URL + cta2Href.slice(1)} class="btn btn-outline">{cta2}</a>
      </div>
    </div>
  </div>

  <!-- Bottom decorative line -->
  <div class="h-1 bg-gradient-to-r from-primary via-accent to-primary opacity-40"></div>
</section>
