---
interface Props {
  icon: string;
  title: string;
  description: string;
  index: number;
}

const { icon, title, description, index } = Astro.props;

const icons: Record<string, string> = {
  guarantee: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  compass: 'M12 2a10 10 0 1010 10A10 10 0 0012 2zm1 14.93V19h-2v-2.07A7.06 7.06 0 015.07 13H3v-2h2.07A7.06 7.06 0 0111 5.07V3h2v2.07A7.06 7.06 0 0118.93 11H21v2h-2.07A7.06 7.06 0 0113 16.93zM12 8a4 4 0 104 4 4 4 0 00-4-4z',
  briefcase: 'M20 7h-4V5a3 3 0 00-6 0v2H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM10 5a1 1 0 012 0v2h-2V5zm-4 6h4v2H6v-2zm6 0h4v2h-4v-2z',
};
---

<div class="card text-center group" style={`animation-delay: ${index * 0.1}s`}>
  <div class="w-14 h-14 mx-auto mb-5 rounded-xl bg-primary-light text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors duration-300">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d={icons[icon] || icons.guarantee} />
    </svg>
  </div>
  <h3 class="text-xl mb-3">{title}</h3>
  <p class="text-text-light leading-relaxed">{description}</p>
</div>
