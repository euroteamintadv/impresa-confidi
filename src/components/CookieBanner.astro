<!-- Cookie Banner -->
<div id="cookie-banner" class="cookie-banner hidden" role="alert" aria-label="Cookie consent">
  <div class="container-custom flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p class="text-text-light text-sm max-w-2xl">
      Utilizziamo solo cookie tecnici essenziali per il funzionamento del sito. Non utilizziamo cookie di profilazione.
      Per maggiori informazioni, consulta la nostra <a href="/cookie" class="text-primary underline hover:text-primary-dark">Cookie Policy</a>.
    </p>
    <button
      id="cookie-accept"
      class="btn btn-primary text-sm px-5 py-2 flex-shrink-0"
    >
      Ho capito
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const accept = document.getElementById('cookie-accept');

  if (!localStorage.getItem('cookie-consent')) {
    if (banner) banner.classList.remove('hidden');
  }

  if (accept) {
    accept.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'true');
      if (banner) banner.classList.add('hidden');
    });
  }
</script>
